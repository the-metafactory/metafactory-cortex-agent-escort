# metafactory-cortex-agent-escort — principal overlay config (EXAMPLE)
#
# Copy this to ~/.config/metafactory/escort/.env and edit. It is read at brain
# startup (brain/env.ts) and lets YOU — the installing principal — choose your
# agent's identity WITHOUT editing the installed pack, so `arc upgrade` and
# clean reinstalls never overwrite your choices.

# The ASSISTANT NAME — the named being this agent hosts. The greeting and the
# in-thread @-mention instruction use it, so two principals who both install
# this pack run e.g. "Escort" and "Warden", not two clones. Per cortex's
# ubiquitous language: the name is config, never contract — the agent id
# (`escort`) stays stable regardless of what you call the assistant.
ESCORT_DISPLAY_NAME="Escort"

# Optional: point at your own persona file. Resolution order (first hit wins):
#   1. this path (ESCORT_PERSONA)
#   2. ~/.config/metafactory/escort/persona.md   (drop a file here)
#   3. the pack's shipped persona.md             (default)
# ESCORT_PERSONA="/Users/you/.config/metafactory/escort/persona.md"

# Optional: the hybrid voice switch (compose, cortex#2257). DEFAULT OFF —
# deterministic at the anonymous edge (prompt-injection posture); enable only
# for trusted-audience deployments, TOGETHER with the host-side
# `runtime.brain.compose: true` on the deployed agent fragment. With either
# off, every reply is the exact canned line. See README.md "The hybrid voice".
# ESCORT_VOICE="on"
